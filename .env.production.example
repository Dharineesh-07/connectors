# Root .env for docker-compose.prod.yml
# Copy to .env (or set these as environment variables on the server) before running.
# Do NOT commit the filled-in version to git.

# PostgreSQL password used by both the postgres service and backend DATABASE_URL override
POSTGRES_PASSWORD=change_me_use_a_strong_password

# Frontend build-time URLs — must use https:// and wss:// in production
VITE_BACKEND_URL=https://yourdomain.com
VITE_BACKEND_WS_URL=wss://yourdomain.com
