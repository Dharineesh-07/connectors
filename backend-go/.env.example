# Database (PostgreSQL DSN format)
DATABASE_URL=host=localhost port=5432 user=postgres password=password dbname=orgchat sslmode=disable TimeZone=UTC

# Redis
REDIS_URL=redis://localhost:6379

# JWT secret (min 32 chars)
SECRET_KEY=your-super-secret-key-min-32-chars-here

# Only allow registration from this domain
COMPANY_EMAIL_DOMAIN=company.com

# File uploads
MAX_FILE_SIZE_MB=10
UPLOADS_DIR=./uploads

# AWS S3 (optional — leave blank to use local storage)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# WebRTC TURN server
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=turnuser
TURN_CREDENTIAL=turnpassword

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
