# ── Docker / local dev shared vars ─────────────────────────────────────────
# MySQL root password — used by both the mysql service and DATABASE_URL below
MYSQL_ROOT_PASSWORD=rootpassword

# ── Backend ─────────────────────────────────────────────────────────────────
# For local dev: set host to localhost. For Docker: set to "mysql"
DATABASE_URL=mysql+aiomysql://root:rootpassword@localhost:3306/orgchat
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Only users with this email domain can register
COMPANY_EMAIL_DOMAIN=yourcompany.com

MAX_FILE_SIZE_MB=10

# AWS S3 for file storage (leave blank to use local disk)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Coturn TURN server for WebRTC NAT traversal (leave blank for LAN-only)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
