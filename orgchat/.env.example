# Copy this file to .env and fill in the values before running docker compose

# MySQL root password — shared by the mysql service and the backend DATABASE_URL
MYSQL_ROOT_PASSWORD=

# FastAPI JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string

# Only users with this email domain can register
COMPANY_EMAIL_DOMAIN=cnc.com

# Token lifetimes (optional — defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Max upload size in MB
MAX_FILE_SIZE_MB=10

# AWS S3 for file storage (leave blank to use local disk)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Coturn TURN server for WebRTC NAT traversal (leave blank for LAN-only)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
